<Window x:Class="DwmLutGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DwmLutGUI"
        mc:Ignorable="d"
        Title="dwm_lut" Height="560" Width="920" MinHeight="520" MinWidth="760"
        Background="#0B1020" Foreground="#E5E7EB" FontFamily="Segoe UI">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="PageBg" Color="#0B1020" />
        <SolidColorBrush x:Key="CardBg" Color="#111827" />
        <SolidColorBrush x:Key="CardBorder" Color="#243044" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF" />
        <SolidColorBrush x:Key="Accent" Color="#38BDF8" />
        <SolidColorBrush x:Key="AccentHover" Color="#0EA5E9" />
        <SolidColorBrush x:Key="Danger" Color="#EF4444" />
        <SolidColorBrush x:Key="InputBg" Color="#0F172A" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E5E7EB" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#374151" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#04111D" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3B1518" />
            <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
            <Setter Property="Foreground" Value="#FCA5A5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#243044" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#0F172A" />
            <Setter Property="AlternatingRowBackground" Value="#111C31" />
            <Setter Property="HorizontalGridLinesBrush" Value="#243044" />
            <Setter Property="VerticalGridLinesBrush" Value="#243044" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#172033" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="BorderBrush" Value="#243044" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBg}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="dwm_lut" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0"
                               Text="Windows 11 25H2 desktop LUT injector" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#062D3F" BorderBrush="#155E75" BorderThickness="1"
                            CornerRadius="999" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding ActiveText, StringFormat=Status: {0}}"
                                   Foreground="#7DD3FC" FontWeight="SemiBold" />
                    </Border>
                    <Button Content="Open Log" Click="OpenLog_Click" Margin="0,0,8,0" />
                    <Button Content="About" Click="AboutButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="Displays" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,0"
                                   Text="Select a display, assign SDR/HDR LUT files, then apply." />
                    </StackPanel>

                    <DataGrid SelectedItem="{Binding SelectedMonitor}" ItemsSource="{Binding Monitors}" RowHeaderWidth="0"
                              IsReadOnly="{Binding IsActive}" AutoGenerateColumns="False"
                              CanUserReorderColumns="False" CanUserSortColumns="False" CanUserResizeColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding SourceId}" IsReadOnly="True" Width="40" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="90" />
                            <DataGridTextColumn Header="Connector" Binding="{Binding Connector}" IsReadOnly="True" Width="110" />
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" IsReadOnly="True" Width="80" />
                            <DataGridTemplateColumn Header="SDR LUT" Width="*" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SdrLutFilename, Mode=OneWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding SdrLuts}" SelectedItem="{Binding SdrLutPath, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="38">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Content="-" Padding="6,2" MinHeight="22" Click="RemoveSdrLut_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="HDR LUT" Width="*" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HdrLutFilename, Mode=OneWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding HdrLuts}" SelectedItem="{Binding HdrLutPath, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="38">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Content="-" Padding="6,2" MinHeight="22" Click="RemoveHdrLut_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="LUT setup" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,14"
                                   Text="Paths are saved automatically for the selected display." />

                        <TextBlock Text="SDR LUT" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                                     Text="{Binding SdrLutPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                    IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                                    Click="SdrLutBrowse_Click" />
                            <Button Grid.Column="2" Content="Clear" Margin="8,0,0,0"
                                    IsEnabled="{Binding SdrLutPath, TargetNullValue=false}"
                                    Click="SdrLutClear_Click" />
                        </Grid>

                        <TextBlock Text="HDR LUT" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                                     Text="{Binding HdrLutPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                    IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                                    Click="HdrLutBrowse_Click" />
                            <Button Grid.Column="2" Content="Clear" Margin="8,0,0,0"
                                    IsEnabled="{Binding HdrLutPath, TargetNullValue=false}"
                                    Click="HdrLutClear_Click" />
                        </Grid>

                        <Button Content="Load included SDR test LUT" Click="LoadTestLut_Click" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Controls" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,14"
                                   Text="Apply injects into DWM. Closing the app disables first." />

                        <TextBlock Text="Toggle key" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ComboBox x:Name="ToggleKeyCombo" SelectedItem="{Binding ToggleKey}" Margin="0,0,0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" IsEnabled="{Binding CanApply}"
                                    Content="Apply LUT" Click="Apply_Click" />
                            <Button Grid.Column="2" Style="{StaticResource DangerButton}" IsEnabled="{Binding IsActive}"
                                    Content="Disable" Click="Disable_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Style="{StaticResource MutedText}" HorizontalAlignment="Center"
                   Text="Tip: minimize keeps the LUT active; closing disables and unloads dwm_lut.dll." />
    </Grid>
</Window>
